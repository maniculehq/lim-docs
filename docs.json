{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Limrun",
  "description": "Run Xcode and iOS, Android, and Linux sandboxes in the cloud, controllable from any language or coding agent.",
  "colors": {
    "primary": "#26BD6C",
    "light": "#5BE093",
    "dark": "#0F5E33"
  },
  "background": {
    "decoration": "grid"
  },
  "favicon": "/favicon.svg",
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "pages": [
              "quickstart"
            ]
          },
          {
            "group": "Remote iOS development",
            "icon": "smartphone",
            "pages": [
              "ios/build-with-xcode",
              "ios/run-simulator",
              "ios/control-instance"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/limrun-inc"
        },
        {
          "anchor": "Console",
          "icon": "layout-dashboard",
          "href": "https://console.limrun.com"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/limrun-inc"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get an API key",
      "href": "https://console.limrun.com"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/limrun-inc",
      "website": "https://lim.run"
    }
  }
}
