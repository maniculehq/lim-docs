{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Limrun",
  "description": "Run iOS simulators, Android emulators, and Xcode builds in the cloud, controllable from any language, CLI, or coding agent.",
  "colors": {
    "primary": "#26BD6C",
    "light": "#5BE093",
    "dark": "#0F5E33"
  },
  "background": {
    "decoration": "grid"
  },
  "favicon": "/favicon.svg",
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Quickstart for coding agents",
            "icon": "bot",
            "pages": [
              "agents/cli",
              "agents/mcp"
            ]
          },
          {
            "group": "Remote iOS development",
            "icon": "smartphone",
            "pages": [
              "ios/build-with-xcode",
              "ios/run-simulator",
              "ios/pr-previews",
              "ios/in-app-purchases"
            ]
          },
          {
            "group": "Remote Android development",
            "icon": "tablet-smartphone",
            "pages": [
              "android/run-emulator"
            ]
          },
          {
            "group": "Automated testing",
            "icon": "flask-conical",
            "pages": [
              "testing/appium",
              "testing/playwright"
            ]
          },
          {
            "group": "Platform integration",
            "icon": "blocks",
            "pages": [
              "platform/embed-simulator",
              "platform/asset-storage"
            ]
          },
          {
            "group": "Reference",
            "icon": "book-open",
            "pages": [
              "reference"
            ]
          }
        ]
      },
      {
        "tab": "Examples",
        "anchors": [
          {
            "anchor": "iOS samples",
            "icon": "smartphone",
            "href": "https://github.com/limrun-inc/typescript-sdk/tree/main/examples"
          },
          {
            "anchor": "Sample native app",
            "icon": "github",
            "href": "https://github.com/limrun-inc/sample-native-app"
          },
          {
            "anchor": "Sample Flutter app",
            "icon": "github",
            "href": "https://github.com/limrun-inc/sample-flutter-app"
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/limrun-inc"
        },
        {
          "anchor": "Console",
          "icon": "layout-dashboard",
          "href": "https://console.limrun.com"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/limrun-inc"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get an API key",
      "href": "https://console.limrun.com"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/limrun-inc",
      "website": "https://lim.run"
    }
  }
}
